    "@fastify/rate-limit": "^10.3.0",
    "@market-desk/analysis-engine": "workspace:*",
    "@market-desk/compliance": "workspace:*",
    "@market-desk/core": "workspace:*",
    "@market-desk/data-providers": "workspace:*",
    "@market-desk/shared": "workspace:*",
    "@market-desk/telegram": "workspace:*",
    "bullmq": "^5.56.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "ioredis": "^5.6.1",
    "pino": "^10.3.1",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
