services:
  - type: web
    name: market-desk-api
    runtime: docker
    dockerfilePath: ./apps/api/Dockerfile
    plan: starter
    healthCheckPath: /health
    envVars:
      - key: NODE_ENV
        value: production
      - key: API_AUTH_REQUIRED
        value: "true"
      - key: DATABASE_URL
        fromDatabase:
          name: market-desk-postgres
          property: connectionString
      - key: REDIS_URL
        fromService:
          type: redis
          name: market-desk-redis
          property: connectionString
      - key: ADMIN_API_TOKEN
        sync: false
      - key: OPENAI_API_KEY
        sync: false
      - key: TELEGRAM_BOT_TOKEN
        sync: false

  - type: web
    name: market-desk-dashboard
    runtime: docker
    dockerfilePath: ./apps/dashboard/Dockerfile
    plan: starter
    healthCheckPath: /
    envVars:
      - key: NODE_ENV
        value: production
      - key: API_BASE_URL
        sync: false
      - key: DASHBOARD_API_TOKEN
        sync: false
      - key: DASHBOARD_BASIC_AUTH_USER
        sync: false
      - key: DASHBOARD_BASIC_AUTH_PASSWORD
        sync: false

  - type: redis
    name: market-desk-redis
    plan: starter
    ipAllowList: []

databases:
  - name: market-desk-postgres
    plan: starter
    databaseName: marketdesk
    user: marketdesk
