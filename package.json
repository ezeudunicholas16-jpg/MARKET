{
  "name": "market-desk-engine",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @market-desk/api --filter @market-desk/dashboard dev",
    "dev:api": "pnpm --filter @market-desk/api dev",
    "dev:dashboard": "pnpm --filter @market-desk/dashboard dev",
    "dev:telegram-test": "pnpm --filter @market-desk/api telegram:test",
    "lint": "pnpm -r lint",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit && pnpm --filter @market-desk/dashboard typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css,prisma,yml,yaml}\"",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:watchlist": "tsx prisma/seed-production-watchlist.ts",
    "telegram:webhook": "tsx scripts/set-telegram-webhook.ts",
    "postinstall": "prisma generate --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@next/eslint-plugin-next": "^15.5.18",
    "@types/node": "^22.15.29",
    "eslint-config-next": "^15.5.18",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "prisma": "^6.19.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.2"
  }
}
